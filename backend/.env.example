# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For PostgreSQL (production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=weather_prediction
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# For SQLite (development)
USE_SQLITE=True

# JWT Token Settings
JWT_ACCESS_LIFETIME=60
JWT_REFRESH_LIFETIME=7

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenWeatherMap API
OPENWEATHER_API_KEY=your-openweather-api-key

# ML Model Paths (relative to backend directory)
ML_MODEL_PATH=ml_models/rainfall_model.pkl
ML_SCALER_PATH=ml_models/scaler.pkl
